<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VerificarEdad.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label Text="¡Determina si eres mayor de edad!"
                   Style="{StaticResource Headline}"/>
            <Label Text="Escribe tu edad:"
                   TextColor="#3a4a3a"
                   FontSize="14"
                   VerticalOptions="Center"/>
            <Entry x:Name="txtEdad"
                   Placeholder="edad:"
                   Keyboard="Numeric"
                   FontSize="14"/>
            <Button Text="Calcular"
                    CornerRadius="10"
                    Clicked="OnContarClicked"
                    FontSize="16"/>
            <Label x:Name="lblResultado"
                   Text=""
                   TextColor="Blue"
                   FontSize="18"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
